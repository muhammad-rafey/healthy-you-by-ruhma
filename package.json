{
  "name": "healthy-you-by-ruhma",
  "version": "0.9.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm build",
    "prepare": "husky",
    "media:migrate": "tsx scripts/migrate-media.ts",
    "content:check": "tsx scripts/check-content.ts",
    "wordmark:optimize": "tsx scripts/optimize-wordmark.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@vercel/og": "^0.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "16.2.5",
    "next-mdx-remote": "^6.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "eslint-config-prettier": "^9",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,mdx,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
